# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing & coverage
/coverage
*.lcov

# Next.js
/.next/
/out/

# Production
/build
/dist

# cPanel deploy bundle (regenerate with npm run zip:cpanel)
/public/pockit-cpanel-site.zip

# Misc
.DS_Store
*.pem
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Local env (never commit secrets)
.env
.env.*

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Caches & tooling
.turbo
.cache
.eslintcache
.parcel-cache
.stylelintcache

# IDE / local agent configs (do not ship to client repos)
.idea/
.vscode/*
!.vscode/extensions.json
.claude/
.embold/

# OS
Thumbs.db
